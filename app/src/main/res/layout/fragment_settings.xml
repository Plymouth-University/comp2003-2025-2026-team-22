<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="#F5F7FA"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_account_circle"
                    app:tint="@color/primary"/>
            </LinearLayout>

            <!-- PROFILE -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Profile"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/nameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Name"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveProfileButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Save profile"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- HOUSEHOLD -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Household"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/flatNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Flat / house name"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveFlatButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Save household"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:text="Invite / Join code"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/joinCodeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set"
                        android:textSize="18sp"
                        android:layout_marginTop="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/generateJoinCodeButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Generate"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/copyJoinCodeButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Copy"
                            android:layout_marginStart="8dp"/>

                    </LinearLayout>

                    <!-- JOIN HOUSEHOLD -->

                    <EditText
                        android:id="@+id/joinCodeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Enter join code"
                        android:inputType="text"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/joinFlatButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Join Household"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ACCOUNT -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Account"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/changePasswordButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Change password"
                        android:layout_marginTop="8dp"/>

                    <Button
                        android:id="@+id/changeEmailButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Change email"
                        android:layout_marginTop="8dp"/>

                    <Button
                        android:id="@+id/logoutButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- PREFERENCES -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Preferences"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Spinner
                        android:id="@+id/themeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/applyThemeButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Apply Theme"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/notificationsSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable reminders"/>

                    <Button
                        android:id="@+id/notificationTimeButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reminder Time"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/biometricSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Use biometrics"/>

                    <Spinner
                        android:id="@+id/reloginSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/applyReloginButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Apply security"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SUPPORT -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Support"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button android:id="@+id/faqButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="FAQ"/>
                    <Button android:id="@+id/reportProblemButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Report Problem"/>
                    <Button android:id="@+id/termsButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Terms"/>
                    <Button android:id="@+id/privacyButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Privacy"/>
                    <Button android:id="@+id/aboutButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="About"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- DATA -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Data"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button android:id="@+id/exportButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Export Settings"/>
                    <Button android:id="@+id/clearCompletedButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Clear Completed Chores"/>
                    <Button android:id="@+id/resetHintsButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Reset Hints"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- DANGER ZONE -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:text="Danger Zone"
                        android:textColor="#D32F2F"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/deleteAccountButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Delete account"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="#D32F2F"
                        android:textColor="@android:color/white"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>